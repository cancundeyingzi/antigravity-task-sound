{
  "name": "antigravity-task-sound",
  "displayName": "Antigravity Task Sound",
  "description": "Play sound notifications when Antigravity AI Agent completes a response. Supports English & Chinese.",
  "version": "3.0.0",
  "publisher": "1582182391",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/liukunpeng0316/antigravity-task-sound"
  },
  "homepage": "https://github.com/liukunpeng0316/antigravity-task-sound#readme",
  "bugs": {
    "url": "https://github.com/liukunpeng0316/antigravity-task-sound/issues"
  },
  "keywords": [
    "antigravity",
    "ai",
    "notification",
    "sound",
    "task",
    "cdp",
    "agent"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravityTaskSound.showMenu",
        "title": "Antigravity Task Sound: Settings Menu"
      },
      {
        "command": "antigravityTaskSound.testSound",
        "title": "Antigravity Task Sound: Test Sound"
      },
      {
        "command": "antigravityTaskSound.toggle",
        "title": "Antigravity Task Sound: Toggle"
      },
      {
        "command": "antigravityTaskSound.connectCdp",
        "title": "Antigravity Task Sound: Connect CDP"
      }
    ],
    "configuration": {
      "title": "Antigravity Task Sound",
      "properties": {
        "antigravityTaskSound.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable task completion sound notification"
        },
        "antigravityTaskSound.cdpEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable CDP protocol to detect AI response completion (requires Antigravity launched with --remote-debugging-port)"
        },
        "antigravityTaskSound.cdpPort": {
          "type": "number",
          "default": 9000,
          "description": "Antigravity remote debugging port (matches --remote-debugging-port launch argument)"
        },
        "antigravityTaskSound.soundFile": {
          "type": "string",
          "default": "",
          "description": "Custom sound file path (.wav), leave empty for built-in sound"
        },
        "antigravityTaskSound.volume": {
          "type": "number",
          "default": 50,
          "minimum": 0,
          "maximum": 100,
          "description": "Volume (0-100)"
        },
        "antigravityTaskSound.persistentAlert": {
          "type": "boolean",
          "default": false,
          "description": "Persistent alert mode: loops notification sound after AI completes until dismissed"
        },
        "antigravityTaskSound.persistentAlertInterval": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "maximum": 10000,
          "description": "Playback interval in persistent alert mode (milliseconds)"
        },
        "antigravityTaskSound.language": {
          "type": "string",
          "default": "zh-CN",
          "enum": ["zh-CN", "en"],
          "enumDescriptions": ["中文 (简体)", "English"],
          "description": "UI language / 界面语言"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
